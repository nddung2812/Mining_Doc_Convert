# --- Auth (REQUIRED on any deployment; optional locally) -----------------
# When set, every page and API route requires this password.
# When unset (local dev only), the app is open.
APP_PASSWORD=

# --- Extraction engine ----------------------------------------------------
# Optional server-side Anthropic API key. Users can always bring their own
# key via Settings (sent per-request, never stored server-side).
# Local dev without any key falls back to the Claude Code CLI (`claude -p`),
# which is covered by your Claude subscription.
ANTHROPIC_API_KEY=

# Force an engine instead of auto-resolution: "api" or "cli".
EXTRACTION_ENGINE=

# Model used for extraction.
CLAUDE_MODEL=claude-opus-4-8

# --- Cost guardrail -------------------------------------------------------
# Hard daily cap (USD) on API-engine spend. CLI/subscription runs don't count.
DAILY_COST_CAP_USD=10

# --- Storage --------------------------------------------------------------
# Set automatically when you attach a Vercel Blob store to the project.
# When unset, runs are stored on the local filesystem under ./data/runs.
BLOB_READ_WRITE_TOKEN=
